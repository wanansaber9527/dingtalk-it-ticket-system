# Production database. Use MySQL on Ubuntu server.
DATABASE_URL="mysql://it_ticket:CHANGE_ME@127.0.0.1:3306/it_ticket"

# Local development identity fallback.
DEV_AUTH_ENABLED="true"
DEV_DINGTALK_USER_ID="demo-super"
DEV_USER_NAME="超级管理员"
DEV_USER_MOBILE="13800000000"
DEV_USER_DEPARTMENT_ID="dept-it"
DEV_USER_DEPARTMENT_NAME="信息技术部"
DEV_USER_POSITION="IT负责人"

# Signed login cookie secret. In production, set a long random value.
AUTH_COOKIE_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Public DingTalk H5 entry URL. Used by work notice buttons.
APP_BASE_URL="https://your-domain.example.com"

# DingTalk app parameters.
DINGTALK_CLIENT_ID=""
DINGTALK_CLIENT_SECRET=""
DINGTALK_CORP_ID=""
DINGTALK_AGENT_ID=""
NEXT_PUBLIC_DINGTALK_CORP_ID=""
NEXT_PUBLIC_DINGTALK_JSAPI_URL="https://g.alicdn.com/dingding/dingtalk-jsapi/3.0.41/dingtalk.open.js"

# DingTalk endpoint configuration.
# Keep these configurable so official OpenAPI paths can be filled in later.
DINGTALK_ACCESS_TOKEN_URL=""
DINGTALK_USERID_BY_CODE_URL=""
DINGTALK_USER_DETAIL_URL_TEMPLATE=""
DINGTALK_DEPARTMENT_DETAIL_URL_TEMPLATE=""
DINGTALK_WORK_NOTICE_URL=""
DINGTALK_MOCK_ENABLED="true"

# DingTalk interactive card notification.
# Requires the internal app robot capability and robot message permission.
DINGTALK_INTERACTIVE_CARD_ENABLED="false"
DINGTALK_INTERACTIVE_CARD_TEMPLATE_ID="StandardCard"
DINGTALK_INTERACTIVE_CARD_ROBOT_CODE=""
DINGTALK_INTERACTIVE_CARD_SEND_URL="https://api.dingtalk.com/v1.0/im/v1.0/robot/interactiveCards/send"
DINGTALK_INTERACTIVE_CARD_CALLBACK_URL=""
DINGTALK_INTERACTIVE_CARD_LOGO=""

# Business switches.
INCLUDE_DEMO_DATA="true"
DEFAULT_HANDLER_USER_ID=""
DEFAULT_HANDLER_NAME=""
SLA_DUE_SOON_MINUTES="120"
SLA_CRON_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
